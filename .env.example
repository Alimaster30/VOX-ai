# VOX deployment settings
# Copy this file to .env and adjust values for the target server.

# App mode
VOX_PRODUCTION=0
VOX_SECRET_KEY=change-this-to-a-long-random-secret-before-production
VOX_ADMIN_TOKEN=change-this-to-a-long-random-admin-token
VOX_HOST=0.0.0.0
VOX_PORT=5000
VOX_DEBUG=0
VOX_WAITRESS_THREADS=8

# Organization
VOX_ORG_ID=default

# Model runtime
VOX_AUTOLOAD_MODELS=1
VOX_LLM_MODEL=qwen3.2:3b
VOX_EMBED_MODEL=nomic-embed-text
VOX_CONFIDENCE_THRESHOLD=0.5

# Runtime limits
VOX_MAX_UPLOAD_MB=50
VOX_MAX_UPLOAD_PDF_PAGES=500
VOX_MAX_UPLOAD_SPREADSHEET_CELLS=250000
VOX_MAX_UPLOAD_ZIP_RATIO=20
# Optional malware scanner command. VOX appends the uploaded file path as the final argument.
# Example Linux: VOX_UPLOAD_SCAN_COMMAND=clamscan --no-summary
# Example Windows: VOX_UPLOAD_SCAN_COMMAND=C:\Program Files\ClamAV\clamscan.exe --no-summary
VOX_UPLOAD_SCAN_COMMAND=
VOX_ANSWER_CACHE_ENABLED=1
VOX_ANSWER_CACHE_TTL_SECONDS=86400
VOX_ANSWER_CACHE_MIN_CONFIDENCE=0.65
VOX_MAX_HISTORY=6
VOX_SAMPLE_RATE=16000
VOX_MAX_CONCURRENT_STT=2
VOX_MAX_CONCURRENT_QUERIES=4
VOX_SESSION_TTL_SECONDS=3600
VOX_RATE_LIMIT_WINDOW_SECONDS=60
VOX_RATE_LIMIT_VOICE=30
VOX_RATE_LIMIT_UPLOAD=10
VOX_RATE_LIMIT_ADMIN=120
VOX_DB_BACKEND=sqlite
VOX_DB_PATH=./runtime_cache/vox.sqlite3
# Reserved for PostgreSQL rollout. Example: postgresql://vox:password@localhost:5432/vox
VOX_DATABASE_URL=
# inline runs jobs inside Flask; external queues jobs for worker.py.
VOX_JOB_MODE=inline

# Text-to-speech
# kokoro is local-first. Set fallback to gtts or edge only if network fallback is acceptable.
VOX_TTS_ENGINE=kokoro
VOX_TTS_FALLBACK_ENGINE=none
VOX_TTS_KOKORO_VOICE_EN=af_heart
# Leave blank unless you have a Kokoro voice that supports your target Urdu voice/language.
VOX_TTS_KOKORO_VOICE_UR=

# Production logs
VOX_LOG_DIR=./logs
VOX_LOG_LEVEL=INFO
VOX_LOG_MAX_BYTES=5242880
VOX_LOG_BACKUP_COUNT=5
VOX_MAINTENANCE_AUDIT_RETENTION_DAYS=30
VOX_MAINTENANCE_JOB_RETENTION_DAYS=14
VOX_MAINTENANCE_HANDOFF_RETENTION_DAYS=90

# Optional override. Leave blank to use the organization's profile.json path.
# VOX_INTENTS_PATH=
